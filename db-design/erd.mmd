  app_user {
    uuid id PK
    text display_name
    text department
    text role_name
  }

  work_order {
    uuid id PK
    text work_order_no UK
    text work_order_type "P/C/R/J"
    text status
    uuid source_work_order_id FK
  }

  document_sequence {
    uuid id PK
    text document_type
    date sequence_date
    text site_code
    text target_code
    integer last_sequence
  }

  pm_work_order {
    uuid work_order_id PK
    text pm_code
    date plan_start_date
    date latest_finish_date
    jsonb form_snapshot
  }

  fault_work_order {
    uuid work_order_id PK
    text fault_category
    uuid removed_asset_id FK
    uuid installed_asset_id FK
  }

  repair_work_order {
    uuid work_order_id PK
    uuid removed_asset_id FK
    text repair_method
    text current_place
    text outsourcing_status
    text acceptance_result
  }

  workflow_option {
    text option_group PK
    text option_code PK
    text option_label
    integer sort_order
    boolean is_terminal
    boolean is_active
  }

  material {
    uuid id PK
    text part_no UK
    text material_name
    text system_code
    text category_code
    text type_code
    text system_name
    text material_type
    boolean is_serialized
    boolean repairable
  }

  material_usage_history {
    uuid id PK
    uuid material_id FK
    text period_type
    integer roc_year
    integer usage_month
    text usage_type
    decimal qty
  }

  inventory_document {
    uuid id PK
    text document_no UK
    text document_type
    text movement_type
    text document_status
    date document_date
    text site_code
  }

  inventory_document_line {
    uuid id PK
    uuid inventory_document_id FK
    uuid material_id FK
    uuid asset_id FK
    decimal qty
    text from_stock_status
    text to_stock_status
  }

  warehouse {
    uuid id PK
    text warehouse_code UK
    text warehouse_name
    text location_type
    text default_stock_status
    boolean is_issue_destination
  }

  warehouse_bin {
    uuid id PK
    uuid warehouse_id FK
    text bin_code
    boolean is_active
  }

  asset {
    uuid id PK
    uuid material_id FK
    text serial_no
    text current_status
    uuid current_position_id FK
  }

  asset_event {
    uuid id PK
    uuid asset_id FK
    text event_type
    text from_status
    text to_status
    uuid work_order_id FK
    timestamptz event_at
  }

  inventory_transaction {
    uuid id PK
    uuid material_id FK
    numeric qty_change
    text transaction_type
    uuid work_order_id FK
  }

  inventory_balance {
    uuid material_id PK
    uuid warehouse_id PK
    text stock_status PK
    numeric qty
  }

  inventory_bin_balance {
    uuid material_id PK
    uuid warehouse_id PK
    uuid warehouse_bin_id PK
    text stock_status PK
    numeric qty
  }

  material_import_source {
    uuid id PK
    text import_batch
    text source_file
    integer source_row_no
    text part_no
    text warehouse_code
    text warehouse_location_type
    text bin_code
    text stock_status
    numeric stock_qty
  }
